{
  "manifest_version": 3,
  "name": "Kortex Clipper",
  "version": "1.0",
  "description": "Clip URLs and save notes directly to Kortex",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to Kortex"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://x.com/*",
        "*://twitter.com/*"
      ],
      "js": ["content.js"]
    }
  ]
}
